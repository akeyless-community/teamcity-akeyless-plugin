       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
       default-autowire="constructor">

    <bean id="akeylessOAuthProvider" class="com.akeyless.teamcity.server.AkeylessOAuthProvider"/>
    <bean id="akeylessParameterProvider" class="com.akeyless.teamcity.server.AkeylessParameterProvider"/>
    <bean id="akeylessRemoteParameter" class="com.akeyless.teamcity.server.AkeylessRemoteParameter"/>
    <bean id="akeylessBuildStartProcessor" class="com.akeyless.teamcity.server.AkeylessBuildStartProcessor"/>

</beans>
